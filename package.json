{
  "name": "@jonymei/urn-cli",
  "version": "0.1.1",
  "description": "Collect, normalize, redact, and query local work activity for AI agents",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "src/bin",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonymei/urn.git"
  },
  "bugs": {
    "url": "https://github.com/jonymei/urn/issues"
  },
  "homepage": "https://github.com/jonymei/urn#readme",
  "bin": {
    "urn": "src/bin/urn.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli/index.ts",
    "dev": "tsc --watch",
    "prepack": "pnpm build",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "pnpm build && node --test tests/unit/*.test.mjs",
    "test:e2e": "pnpm build && node --test tests/e2e/*.test.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
